# Copy to .streamlit/secrets.toml for LOCAL use, or paste into the Streamlit
# Community Cloud "Secrets" box (App settings -> Secrets) for deployment.
# Never commit the real secrets.toml (it is in .gitignore).

# --- Database (optional) -----------------------------------------------------
# Point SnortForge at an external managed Postgres (e.g. Neon or Supabase free
# tier). Omit to fall back to SQLite, which is EPHEMERAL on Streamlit Community
# Cloud and resets on every redeploy.
SNORTFORGE_DB_URL = "postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# --- Authentication (gates the whole app) ------------------------------------
# When this [auth] block is present, app.py requires sign-in via st.login().
# Remove it to run the app open (local/dev). Requires the Authlib dependency
# (already in requirements.txt). Example below is for Google OIDC; any OpenID
# Connect provider works (Auth0, Microsoft Entra, Okta, ...).
[auth]
redirect_uri = "https://YOUR-APP.streamlit.app/oauth2callback"
cookie_secret = "GENERATE_A_LONG_RANDOM_STRING"
client_id = "YOUR_OAUTH_CLIENT_ID"
client_secret = "YOUR_OAUTH_CLIENT_SECRET"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"
