# Copy this file to .streamlit/secrets.toml for LOCAL use, or paste its
# contents into the Streamlit Community Cloud "Secrets" box (App settings ->
# Secrets) for deployment. Never commit the real secrets.toml.
#
# Point SnortForge at an external managed Postgres (e.g. Neon or Supabase free
# tier). If this is omitted, the app falls back to SQLite, which is EPHEMERAL on
# Streamlit Community Cloud and resets on every redeploy.

SNORTFORGE_DB_URL = "postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"
